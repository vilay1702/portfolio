# OpenAI API key for /api/chat and /api/qualify
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# MongoDB connection string (e.g., Atlas) for chat logging
# https://www.mongodb.com/atlas
MONGODB_URI=
MONGODB_DB=portfolio

# Salt for hashing IPs before storing (random string, keep secret)
IP_HASH_SALT=
